# ────────────────────────────────────────────────────────────
# TuxedoPOS — Environment Variables Template
# Copy this file to .env.development or .env.production
# ────────────────────────────────────────────────────────────

# Backend API base URL (required)
VITE_API_URL=http://localhost:3000/api/v1

# Application name
VITE_APP_NAME=TuxedoPOS

# Environment identifier: development | staging | production
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_MOCK_DATA=false
VITE_ENABLE_OFFLINE_MODE=true
VITE_ENABLE_DEBUG_LOGGING=true

# PWA - enable service worker registration
VITE_PWA_ENABLED=false
